# Cloudflare Workers Static Assets honors this file at the assets root.
# Astro emits content-hashed bundles under /_astro/ and we self-host fonts,
# so both are safe to cache forever (immutable). HTML is left to the default
# revalidating behavior so deploys go live immediately.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800
